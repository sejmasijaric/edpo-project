<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_IntakeService" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.44.0">
  <bpmn:process id="intake_process" isExecutable="true">
    <bpmn:startEvent id="StartEvent_ItemIntakeRequested" name="Item Intake Requested">
      <bpmn:outgoing>Flow_Start_To_ItemArrived</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_StartIntake" messageRef="Message_StartIntake" />
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_Start_To_ItemArrived" sourceRef="StartEvent_ItemIntakeRequested" targetRef="Event_ItemArrivedAtIntake" />
    <bpmn:intermediateCatchEvent id="Event_ItemArrivedAtIntake" name="Item Arrived at Intake Event">
      <bpmn:incoming>Flow_Start_To_ItemArrived</bpmn:incoming>
      <bpmn:outgoing>Flow_ItemArrived_To_MoveCommand</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_ItemArrivedAtIntake" messageRef="Message_ItemArrivedAtIntake" />
    </bpmn:intermediateCatchEvent>
    <bpmn:sequenceFlow id="Flow_ItemArrived_To_MoveCommand" sourceRef="Event_ItemArrivedAtIntake" targetRef="Task_SendMoveToEngraverCommand" />
    <bpmn:sendTask id="Task_SendMoveToEngraverCommand" name="Send VGR Move to Engraver Command" camunda:delegateExpression="${SendMoveItemFromInputToEngraverCommandDelegate}">
      <bpmn:incoming>Flow_ItemArrived_To_MoveCommand</bpmn:incoming>
      <bpmn:outgoing>Flow_MoveCommand_To_ItemLeft</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:sequenceFlow id="Flow_MoveCommand_To_ItemLeft" sourceRef="Task_SendMoveToEngraverCommand" targetRef="Event_ItemLeftIntake" />
    <bpmn:intermediateCatchEvent id="Event_ItemLeftIntake" name="Item Left Intake Event">
      <bpmn:incoming>Flow_MoveCommand_To_ItemLeft</bpmn:incoming>
      <bpmn:outgoing>Flow_ItemLeft_To_ItemArrivedEngraver</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_ItemLeftIntake" messageRef="Message_ItemLeftIntake" />
    </bpmn:intermediateCatchEvent>
    <bpmn:sequenceFlow id="Flow_ItemLeft_To_ItemArrivedEngraver" sourceRef="Event_ItemLeftIntake" targetRef="Event_ItemArrivedAtEngraver" />
    <bpmn:intermediateCatchEvent id="Event_ItemArrivedAtEngraver" name="Item Arrived at Engraver Event">
      <bpmn:incoming>Flow_ItemLeft_To_ItemArrivedEngraver</bpmn:incoming>
      <bpmn:outgoing>Flow_ItemArrivedEngraver_To_End</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_ItemArrivedAtEngraver" messageRef="Message_ItemArrivedAtEngraver" />
    </bpmn:intermediateCatchEvent>
    <bpmn:sequenceFlow id="Flow_ItemArrivedEngraver_To_End" sourceRef="Event_ItemArrivedAtEngraver" targetRef="EndEvent_IntakeCompleted" />
    <bpmn:endEvent id="EndEvent_IntakeCompleted">
      <bpmn:incoming>Flow_ItemArrivedEngraver_To_End</bpmn:incoming>
    </bpmn:endEvent>
  </bpmn:process>
  <bpmn:message id="Message_StartIntake" name="StartIntakeMessage" />
  <bpmn:message id="Message_ItemArrivedAtIntake" name="ItemArrivedAtIntakeMessage" />
  <bpmn:message id="Message_ItemLeftIntake" name="ItemLeftIntakeMessage" />
  <bpmn:message id="Message_ItemArrivedAtEngraver" name="ItemArrivedAtEngraverMessage" />
  <bpmndi:BPMNDiagram id="BPMNDiagram_intake_process">
    <bpmndi:BPMNPlane id="BPMNPlane_intake_process" bpmnElement="intake_process">
      <bpmndi:BPMNShape id="StartEvent_ItemIntakeRequested_di" bpmnElement="StartEvent_ItemIntakeRequested">
        <dc:Bounds x="160" y="117" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="151" y="160" width="55" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_ItemArrivedAtIntake_di" bpmnElement="Event_ItemArrivedAtIntake">
        <dc:Bounds x="280" y="117" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="263" y="160" width="71" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_ItemLeftIntake_di" bpmnElement="Event_ItemLeftIntake">
        <dc:Bounds x="580" y="117" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="561" y="160" width="76" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_ItemArrivedAtEngraver_di" bpmnElement="Event_ItemArrivedAtEngraver">
        <dc:Bounds x="700" y="117" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="680" y="160" width="76" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_IntakeCompleted_di" bpmnElement="EndEvent_IntakeCompleted">
        <dc:Bounds x="820" y="117" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SendMoveToEngraverCommand_di" bpmnElement="Task_SendMoveToEngraverCommand">
        <dc:Bounds x="390" y="95" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_Start_To_ItemArrived_di" bpmnElement="Flow_Start_To_ItemArrived">
        <di:waypoint x="196" y="135" />
        <di:waypoint x="280" y="135" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ItemArrived_To_MoveCommand_di" bpmnElement="Flow_ItemArrived_To_MoveCommand">
        <di:waypoint x="316" y="135" />
        <di:waypoint x="390" y="135" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_MoveCommand_To_ItemLeft_di" bpmnElement="Flow_MoveCommand_To_ItemLeft">
        <di:waypoint x="490" y="135" />
        <di:waypoint x="580" y="135" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ItemLeft_To_ItemArrivedEngraver_di" bpmnElement="Flow_ItemLeft_To_ItemArrivedEngraver">
        <di:waypoint x="616" y="135" />
        <di:waypoint x="700" y="135" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ItemArrivedEngraver_To_End_di" bpmnElement="Flow_ItemArrivedEngraver_To_End">
        <di:waypoint x="736" y="135" />
        <di:waypoint x="820" y="135" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
