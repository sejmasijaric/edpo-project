        <di:waypoint x="760" y="235" />
        <di:waypoint x="822" y="235" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_1altwdy_di" bpmnElement="Flow_1altwdy">
        <di:waypoint x="858" y="135" />
