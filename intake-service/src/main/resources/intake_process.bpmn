<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_IntakeService" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.44.0">
  <bpmn:process id="intake_process" isExecutable="true">
    <bpmn:startEvent id="StartEvent_ItemIntakeRequested" name="Item Intake Requested">
      <bpmn:outgoing>Flow_Start_To_ItemArrived</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_StartIntake" messageRef="Message_StartIntake" />
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_Start_To_ItemArrived" sourceRef="StartEvent_ItemIntakeRequested" targetRef="Event_ItemArrivedAtIntake" />
    <bpmn:sequenceFlow id="Flow_ItemArrived_To_MoveCommand" sourceRef="Event_ItemArrivedAtIntake" targetRef="Task_SendMoveToEngraverCommand" />
    <bpmn:sendTask id="Task_SendMoveToEngraverCommand" name="Send VGR Move to Engraver Command" camunda:delegateExpression="${SendMoveItemFromInputToEngraverCommandDelegate}">
      <bpmn:incoming>Flow_ItemArrived_To_MoveCommand</bpmn:incoming>
      <bpmn:outgoing>Flow_1eqmqll</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:sendTask id="Task_PublishIntakeCompletedOutcome" name="Send Intake Completed Outcome Event" camunda:delegateExpression="${PublishIntakeCompletedOutcomeDelegate}">
      <bpmn:incoming>Flow_0b78dnt</bpmn:incoming>
      <bpmn:outgoing>Flow_1wtfhcr</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="EndEvent_IntakeCompleted" name="Item Transported to Oven">
      <bpmn:incoming>Flow_1wtfhcr</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:subProcess id="Activity_1s0cue0" name="Observe VGR Transport">
      <bpmn:incoming>Flow_1eqmqll</bpmn:incoming>
      <bpmn:outgoing>Flow_0b78dnt</bpmn:outgoing>
      <bpmn:startEvent id="Event_0mku6v1">
        <bpmn:outgoing>Flow_0ahu1ay</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:intermediateCatchEvent id="Event_ItemLeftIntake" name="Item Left Intake Event">
        <bpmn:incoming>Flow_008z2xs</bpmn:incoming>
        <bpmn:outgoing>Flow_1altwdy</bpmn:outgoing>
        <bpmn:messageEventDefinition id="MessageEventDefinition_ItemLeftIntake" messageRef="Message_ItemLeftIntake" />
      </bpmn:intermediateCatchEvent>
      <bpmn:intermediateCatchEvent id="Event_ItemArrivedAtEngraver" name="Item Arrived at Engraver Event">
        <bpmn:incoming>Flow_1ooggvl</bpmn:incoming>
        <bpmn:outgoing>Flow_03fn0aa</bpmn:outgoing>
        <bpmn:messageEventDefinition id="MessageEventDefinition_ItemArrivedAtEngraver" messageRef="Message_ItemArrivedAtEngraver" />
      </bpmn:intermediateCatchEvent>
      <bpmn:sequenceFlow id="Flow_008z2xs" sourceRef="Gateway_0qielxx" targetRef="Event_ItemLeftIntake" />
      <bpmn:sequenceFlow id="Flow_1ooggvl" sourceRef="Gateway_0qielxx" targetRef="Event_ItemArrivedAtEngraver" />
      <bpmn:sequenceFlow id="Flow_1altwdy" sourceRef="Event_ItemLeftIntake" targetRef="Gateway_1embq03" />
      <bpmn:parallelGateway id="Gateway_0qielxx">
        <bpmn:incoming>Flow_0ahu1ay</bpmn:incoming>
        <bpmn:outgoing>Flow_008z2xs</bpmn:outgoing>
        <bpmn:outgoing>Flow_1ooggvl</bpmn:outgoing>
      </bpmn:parallelGateway>
      <bpmn:parallelGateway id="Gateway_1embq03">
        <bpmn:incoming>Flow_1altwdy</bpmn:incoming>
        <bpmn:incoming>Flow_03fn0aa</bpmn:incoming>
        <bpmn:outgoing>Flow_1akbs92</bpmn:outgoing>
      </bpmn:parallelGateway>
      <bpmn:sequenceFlow id="Flow_03fn0aa" sourceRef="Event_ItemArrivedAtEngraver" targetRef="Gateway_1embq03" />
      <bpmn:endEvent id="Event_1etyiit" name="VGR Transport Successful">
        <bpmn:incoming>Flow_1akbs92</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_1akbs92" sourceRef="Gateway_1embq03" targetRef="Event_1etyiit" />
      <bpmn:sequenceFlow id="Flow_0ahu1ay" sourceRef="Event_0mku6v1" targetRef="Gateway_0qielxx" />
    </bpmn:subProcess>
    <bpmn:sequenceFlow id="Flow_1eqmqll" sourceRef="Task_SendMoveToEngraverCommand" targetRef="Activity_1s0cue0" />
    <bpmn:sequenceFlow id="Flow_0b78dnt" sourceRef="Activity_1s0cue0" targetRef="Task_PublishIntakeCompletedOutcome" />
    <bpmn:sequenceFlow id="Flow_1wtfhcr" sourceRef="Task_PublishIntakeCompletedOutcome" targetRef="EndEvent_IntakeCompleted" />
    <bpmn:intermediateCatchEvent id="Event_ItemArrivedAtIntake" name="Item Arrived at Intake Event">
      <bpmn:incoming>Flow_Start_To_ItemArrived</bpmn:incoming>
      <bpmn:outgoing>Flow_ItemArrived_To_MoveCommand</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_ItemArrivedAtIntake" messageRef="Message_ItemArrivedAtIntake" />
    </bpmn:intermediateCatchEvent>
  </bpmn:process>
  <bpmn:message id="Message_StartIntake" name="StartIntakeMessage" />
  <bpmn:message id="Message_ItemArrivedAtIntake" name="ItemArrivedAtIntakeMessage" />
  <bpmn:message id="Message_ItemLeftIntake" name="ItemLeftIntakeMessage" />
  <bpmn:message id="Message_ItemArrivedAtEngraver" name="ItemArrivedAtEngraverMessage" />
  <bpmndi:BPMNDiagram id="BPMNDiagram_intake_process">
    <bpmndi:BPMNPlane id="BPMNPlane_intake_process" bpmnElement="intake_process">
      <bpmndi:BPMNShape id="StartEvent_ItemIntakeRequested_di" bpmnElement="StartEvent_ItemIntakeRequested">
        <dc:Bounds x="162" y="167" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="153" y="210" width="55" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_ItemArrivedAtIntake_di" bpmnElement="Event_ItemArrivedAtIntake">
        <dc:Bounds x="282" y="167" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="265" y="210" width="71" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SendMoveToEngraverCommand_di" bpmnElement="Task_SendMoveToEngraverCommand">
        <dc:Bounds x="390" y="145" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_IntakeCompleted_di" bpmnElement="EndEvent_IntakeCompleted">
        <dc:Bounds x="1312" y="167" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1288" y="210" width="84" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_PublishIntakeCompletedOutcome_di" bpmnElement="Task_PublishIntakeCompletedOutcome">
        <dc:Bounds x="1150" y="145" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_1s0cue0_di" bpmnElement="Activity_1s0cue0" isExpanded="true">
        <dc:Bounds x="620" y="85" width="430" height="200" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_0mku6v1_di" bpmnElement="Event_0mku6v1">
        <dc:Bounds x="660" y="167" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_1bgfqf1_di" bpmnElement="Gateway_0qielxx">
        <dc:Bounds x="735" y="160" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_02fbefq_di" bpmnElement="Gateway_1embq03">
        <dc:Bounds x="885" y="160" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_1etyiit_di" bpmnElement="Event_1etyiit">
        <dc:Bounds x="972" y="167" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="953" y="210" width="74" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_ItemLeftIntake_di" bpmnElement="Event_ItemLeftIntake">
        <dc:Bounds x="822" y="117" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="803" y="160" width="76" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_ItemArrivedAtEngraver_di" bpmnElement="Event_ItemArrivedAtEngraver">
        <dc:Bounds x="822" y="217" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="802" y="260" width="76" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_0ahu1ay_di" bpmnElement="Flow_0ahu1ay">
        <di:waypoint x="696" y="185" />
        <di:waypoint x="735" y="185" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_008z2xs_di" bpmnElement="Flow_008z2xs">
        <di:waypoint x="760" y="160" />
        <di:waypoint x="760" y="135" />
        <di:waypoint x="822" y="135" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_1ooggvl_di" bpmnElement="Flow_1ooggvl">
