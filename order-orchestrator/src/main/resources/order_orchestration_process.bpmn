<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_OrderOrchestration" targetNamespace="http://unisg.org/ftengrave/order-orchestrator" exporter="Camunda Modeler" exporterVersion="5.44.0">
  <bpmn:message id="Message_OrderCreated" name="OrderCreatedMessage" />
  <bpmn:message id="Message_IntakeCompletedOutcome" name="IntakeCompletedOutcomeMessage" />
  <bpmn:message id="Message_ManufacturingCompletedOutcome" name="ManufacturingCompletedOutcomeMessage" />
  <bpmn:message id="Message_ManufacturingFailedOutcome" name="ManufacturingFailedOutcomeMessage" />
  <bpmn:message id="Message_QcShippingOutcome" name="QcShippingOutcomeMessage" />
  <bpmn:message id="Message_QcRejectionOutcome" name="QcRejectionOutcomeMessage" />
  <bpmn:process id="OrderOrchestrationProcess" name="Order Orchestration Process" isExecutable="true">
    <bpmn:startEvent id="StartEvent_OrderCreated" name="Order Created Event">
      <bpmn:outgoing>Flow_Start_To_SendRunIntake</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_OrderCreated" messageRef="Message_OrderCreated" />
    </bpmn:startEvent>
    <bpmn:sendTask id="Activity_SendRunIntakeCommand" name="Send Run Intake Command" camunda:delegateExpression="${sendRunIntakeCommandDelegate}">
      <bpmn:incoming>Flow_17f81j5</bpmn:incoming>
      <bpmn:outgoing>Flow_SendRunIntake_To_IntakeCompleted</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:intermediateCatchEvent id="Event_IntakeCompletedOutcome" name="Intake Completed Event">
      <bpmn:incoming>Flow_SendRunIntake_To_IntakeCompleted</bpmn:incoming>
      <bpmn:outgoing>Flow_IntakeCompleted_To_SendRunProduction</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_IntakeCompletedOutcome" messageRef="Message_IntakeCompletedOutcome" />
    </bpmn:intermediateCatchEvent>
    <bpmn:sendTask id="Activity_SendRunProductionCommand" name="Send Run Manufacturing Command" camunda:delegateExpression="${sendRunProductionCommandDelegate}">
      <bpmn:incoming>Flow_IntakeCompleted_To_SendRunProduction</bpmn:incoming>
      <bpmn:outgoing>Flow_SendRunProduction_To_WaitForManufacturingOutcome</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:eventBasedGateway id="Gateway_WaitForManufacturingOutcome" name="Wait for manufacturing outcome">
      <bpmn:incoming>Flow_SendRunProduction_To_WaitForManufacturingOutcome</bpmn:incoming>
      <bpmn:outgoing>Flow_WaitForManufacturingOutcome_To_ManufacturingCompleted</bpmn:outgoing>
      <bpmn:outgoing>Flow_WaitForManufacturingOutcome_To_ManufacturingFailed</bpmn:outgoing>
    </bpmn:eventBasedGateway>
    <bpmn:intermediateCatchEvent id="Event_ManufacturingCompletedOutcome" name="Manufacturing Completed Event">
      <bpmn:incoming>Flow_WaitForManufacturingOutcome_To_ManufacturingCompleted</bpmn:incoming>
      <bpmn:outgoing>Flow_ManufacturingCompleted_To_SendPerformQc</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_ManufacturingCompletedOutcome" messageRef="Message_ManufacturingCompletedOutcome" />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="Event_ManufacturingFailedOutcome" name="Manufacturing Failed Event">
      <bpmn:incoming>Flow_WaitForManufacturingOutcome_To_ManufacturingFailed</bpmn:incoming>
      <bpmn:outgoing>Flow_ManufacturingFailed_To_End</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_ManufacturingFailedOutcome" messageRef="Message_ManufacturingFailedOutcome" />
    </bpmn:intermediateCatchEvent>
    <bpmn:sendTask id="Activity_SendPerformQcCommand" name="Send Perform QC Command" camunda:delegateExpression="${sendPerformQcCommandDelegate}">
      <bpmn:incoming>Flow_ManufacturingCompleted_To_SendPerformQc</bpmn:incoming>
      <bpmn:outgoing>Flow_SendPerformQc_To_WaitForQcOutcome</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:eventBasedGateway id="Gateway_WaitForQcOutcome" name="Wait for QC outcome">
      <bpmn:incoming>Flow_SendPerformQc_To_WaitForQcOutcome</bpmn:incoming>
      <bpmn:outgoing>Flow_WaitForQcOutcome_To_Shipping</bpmn:outgoing>
      <bpmn:outgoing>Flow_WaitForQcOutcome_To_Rejection</bpmn:outgoing>
    </bpmn:eventBasedGateway>
    <bpmn:intermediateCatchEvent id="Event_QcShippingOutcome" name="QC Shipping Event">
      <bpmn:incoming>Flow_WaitForQcOutcome_To_Shipping</bpmn:incoming>
      <bpmn:outgoing>Flow_QcShippingOutcome_To_End</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_QcShippingOutcome" messageRef="Message_QcShippingOutcome" />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="Event_QcRejectionOutcome" name="QC Rejected Event">
      <bpmn:incoming>Flow_WaitForQcOutcome_To_Rejection</bpmn:incoming>
      <bpmn:outgoing>Flow_017kh6m</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_QcRejectionOutcome" messageRef="Message_QcRejectionOutcome" />
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="Event_OrderCompleted" name="Order completed">
      <bpmn:incoming>Flow_QcShippingOutcome_To_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start_To_SendRunIntake" sourceRef="StartEvent_OrderCreated" targetRef="Gateway_1dkrekk" />
    <bpmn:sequenceFlow id="Flow_SendRunIntake_To_IntakeCompleted" sourceRef="Activity_SendRunIntakeCommand" targetRef="Event_IntakeCompletedOutcome" />
    <bpmn:sequenceFlow id="Flow_IntakeCompleted_To_SendRunProduction" sourceRef="Event_IntakeCompletedOutcome" targetRef="Activity_SendRunProductionCommand" />
    <bpmn:sequenceFlow id="Flow_SendRunProduction_To_WaitForManufacturingOutcome" sourceRef="Activity_SendRunProductionCommand" targetRef="Gateway_WaitForManufacturingOutcome" />
    <bpmn:sequenceFlow id="Flow_WaitForManufacturingOutcome_To_ManufacturingCompleted" sourceRef="Gateway_WaitForManufacturingOutcome" targetRef="Event_ManufacturingCompletedOutcome" />
    <bpmn:sequenceFlow id="Flow_WaitForManufacturingOutcome_To_ManufacturingFailed" sourceRef="Gateway_WaitForManufacturingOutcome" targetRef="Event_ManufacturingFailedOutcome" />
    <bpmn:sequenceFlow id="Flow_ManufacturingCompleted_To_SendPerformQc" sourceRef="Event_ManufacturingCompletedOutcome" targetRef="Activity_SendPerformQcCommand" />
    <bpmn:sequenceFlow id="Flow_ManufacturingFailed_To_End" sourceRef="Event_ManufacturingFailedOutcome" targetRef="Gateway_16z6i9i" />
    <bpmn:sequenceFlow id="Flow_SendPerformQc_To_WaitForQcOutcome" sourceRef="Activity_SendPerformQcCommand" targetRef="Gateway_WaitForQcOutcome" />
    <bpmn:sequenceFlow id="Flow_WaitForQcOutcome_To_Shipping" sourceRef="Gateway_WaitForQcOutcome" targetRef="Event_QcShippingOutcome" />
    <bpmn:sequenceFlow id="Flow_WaitForQcOutcome_To_Rejection" sourceRef="Gateway_WaitForQcOutcome" targetRef="Event_QcRejectionOutcome" />
    <bpmn:sequenceFlow id="Flow_QcShippingOutcome_To_End" sourceRef="Event_QcShippingOutcome" targetRef="Event_OrderCompleted" />
    <bpmn:exclusiveGateway id="Gateway_1dkrekk">
      <bpmn:incoming>Flow_Start_To_SendRunIntake</bpmn:incoming>
      <bpmn:incoming>Flow_1ltjyc7</bpmn:incoming>
      <bpmn:outgoing>Flow_17f81j5</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_17f81j5" sourceRef="Gateway_1dkrekk" targetRef="Activity_SendRunIntakeCommand" />
    <bpmn:userTask id="Activity_0s7hwfg" name="Remove Item From Factory">
      <bpmn:extensionElements>
        <camunda:formData />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1n24u8p</bpmn:incoming>
      <bpmn:outgoing>Flow_1ltjyc7</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_1ltjyc7" name="Re-try production" sourceRef="Activity_0s7hwfg" targetRef="Gateway_1dkrekk" />
    <bpmn:exclusiveGateway id="Gateway_16z6i9i">
      <bpmn:incoming>Flow_ManufacturingFailed_To_End</bpmn:incoming>
      <bpmn:incoming>Flow_017kh6m</bpmn:incoming>
      <bpmn:outgoing>Flow_1n24u8p</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_017kh6m" sourceRef="Event_QcRejectionOutcome" targetRef="Gateway_16z6i9i" />
    <bpmn:sequenceFlow id="Flow_1n24u8p" sourceRef="Gateway_16z6i9i" targetRef="Activity_0s7hwfg" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_OrderOrchestration">
    <bpmndi:BPMNPlane id="BPMNPlane_OrderOrchestration" bpmnElement="OrderOrchestrationProcess">
