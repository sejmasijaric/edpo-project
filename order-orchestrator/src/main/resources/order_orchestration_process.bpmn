      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_Flow_IntakeCompleted_To_SendRunProduction" bpmnElement="Flow_IntakeCompleted_To_SendRunProduction">
        <di:waypoint x="588" y="138" />
        <di:waypoint x="780" y="138" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_ManufacturingCompleted_To_SendPerformQc" bpmnElement="Flow_ManufacturingCompleted_To_SendPerformQc">
        <di:waypoint x="1068" y="138" />
