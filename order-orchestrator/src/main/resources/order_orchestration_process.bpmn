<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_OrderOrchestration"
                  targetNamespace="http://unisg.org/ftengrave/order-orchestrator">
  <bpmn:message id="Message_OrderCreated" name="OrderCreatedMessage" />
  <bpmn:message id="Message_IntakeCompletedOutcome" name="IntakeCompletedOutcomeMessage" />
  <bpmn:message id="Message_ManufacturingCompletedOutcome" name="ManufacturingCompletedOutcomeMessage" />
  <bpmn:message id="Message_ManufacturingFailedOutcome" name="ManufacturingFailedOutcomeMessage" />
  <bpmn:message id="Message_QcShippingOutcome" name="QcShippingOutcomeMessage" />
  <bpmn:message id="Message_QcRejectionOutcome" name="QcRejectionOutcomeMessage" />

  <bpmn:process id="OrderOrchestrationProcess" name="Order Orchestration Process" isExecutable="true">
    <bpmn:startEvent id="StartEvent_OrderCreated" name="Order Created Event">
      <bpmn:outgoing>Flow_Start_To_SendRunIntake</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_OrderCreated" messageRef="Message_OrderCreated" />
    </bpmn:startEvent>
    <bpmn:sendTask id="Activity_SendRunIntakeCommand"
                   name="Send Run Intake Command"
                   camunda:delegateExpression="${sendRunIntakeCommandDelegate}">
      <bpmn:incoming>Flow_Start_To_SendRunIntake</bpmn:incoming>
      <bpmn:outgoing>Flow_SendRunIntake_To_IntakeCompleted</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:intermediateCatchEvent id="Event_IntakeCompletedOutcome" name="Intake Completed Outcome">
      <bpmn:incoming>Flow_SendRunIntake_To_IntakeCompleted</bpmn:incoming>
      <bpmn:outgoing>Flow_IntakeCompleted_To_SendRunProduction</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_IntakeCompletedOutcome" messageRef="Message_IntakeCompletedOutcome" />
    </bpmn:intermediateCatchEvent>
    <bpmn:sendTask id="Activity_SendRunProductionCommand"
                   name="Send Run Production Command"
                   camunda:delegateExpression="${sendRunProductionCommandDelegate}">
      <bpmn:incoming>Flow_IntakeCompleted_To_SendRunProduction</bpmn:incoming>
      <bpmn:outgoing>Flow_SendRunProduction_To_WaitForManufacturingOutcome</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:eventBasedGateway id="Gateway_WaitForManufacturingOutcome" name="Wait for manufacturing outcome">
      <bpmn:incoming>Flow_SendRunProduction_To_WaitForManufacturingOutcome</bpmn:incoming>
      <bpmn:outgoing>Flow_WaitForManufacturingOutcome_To_ManufacturingCompleted</bpmn:outgoing>
      <bpmn:outgoing>Flow_WaitForManufacturingOutcome_To_ManufacturingFailed</bpmn:outgoing>
    </bpmn:eventBasedGateway>
    <bpmn:intermediateCatchEvent id="Event_ManufacturingCompletedOutcome" name="Manufacturing Completed Outcome">
      <bpmn:incoming>Flow_WaitForManufacturingOutcome_To_ManufacturingCompleted</bpmn:incoming>
      <bpmn:outgoing>Flow_ManufacturingCompleted_To_SendPerformQc</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_ManufacturingCompletedOutcome" messageRef="Message_ManufacturingCompletedOutcome" />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="Event_ManufacturingFailedOutcome" name="Manufacturing Failed Outcome">
      <bpmn:incoming>Flow_WaitForManufacturingOutcome_To_ManufacturingFailed</bpmn:incoming>
      <bpmn:outgoing>Flow_ManufacturingFailed_To_End</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_ManufacturingFailedOutcome" messageRef="Message_ManufacturingFailedOutcome" />
    </bpmn:intermediateCatchEvent>
    <bpmn:sendTask id="Activity_SendPerformQcCommand"
                   name="Send Perform QC Command"
                   camunda:delegateExpression="${sendPerformQcCommandDelegate}">
      <bpmn:incoming>Flow_ManufacturingCompleted_To_SendPerformQc</bpmn:incoming>
      <bpmn:outgoing>Flow_SendPerformQc_To_WaitForQcOutcome</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:eventBasedGateway id="Gateway_WaitForQcOutcome" name="Wait for QC outcome">
      <bpmn:incoming>Flow_SendPerformQc_To_WaitForQcOutcome</bpmn:incoming>
      <bpmn:outgoing>Flow_WaitForQcOutcome_To_Shipping</bpmn:outgoing>
      <bpmn:outgoing>Flow_WaitForQcOutcome_To_Rejection</bpmn:outgoing>
    </bpmn:eventBasedGateway>
    <bpmn:intermediateCatchEvent id="Event_QcShippingOutcome" name="QC Shipping Outcome">
      <bpmn:incoming>Flow_WaitForQcOutcome_To_Shipping</bpmn:incoming>
      <bpmn:outgoing>Flow_QcShippingOutcome_To_End</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_QcShippingOutcome" messageRef="Message_QcShippingOutcome" />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="Event_QcRejectionOutcome" name="QC Rejection Outcome">
      <bpmn:incoming>Flow_WaitForQcOutcome_To_Rejection</bpmn:incoming>
      <bpmn:outgoing>Flow_QcRejectionOutcome_To_End</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_QcRejectionOutcome" messageRef="Message_QcRejectionOutcome" />
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="Event_OrderCompleted" name="Order completed">
      <bpmn:incoming>Flow_QcShippingOutcome_To_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="Event_OrderRejected" name="Order rejected">
      <bpmn:incoming>Flow_QcRejectionOutcome_To_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="Event_OrderFailed" name="Order failed">
      <bpmn:incoming>Flow_ManufacturingFailed_To_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start_To_SendRunIntake" sourceRef="StartEvent_OrderCreated" targetRef="Activity_SendRunIntakeCommand" />
    <bpmn:sequenceFlow id="Flow_SendRunIntake_To_IntakeCompleted" sourceRef="Activity_SendRunIntakeCommand" targetRef="Event_IntakeCompletedOutcome" />
    <bpmn:sequenceFlow id="Flow_IntakeCompleted_To_SendRunProduction" sourceRef="Event_IntakeCompletedOutcome" targetRef="Activity_SendRunProductionCommand" />
    <bpmn:sequenceFlow id="Flow_SendRunProduction_To_WaitForManufacturingOutcome" sourceRef="Activity_SendRunProductionCommand" targetRef="Gateway_WaitForManufacturingOutcome" />
    <bpmn:sequenceFlow id="Flow_WaitForManufacturingOutcome_To_ManufacturingCompleted" sourceRef="Gateway_WaitForManufacturingOutcome" targetRef="Event_ManufacturingCompletedOutcome" />
    <bpmn:sequenceFlow id="Flow_WaitForManufacturingOutcome_To_ManufacturingFailed" sourceRef="Gateway_WaitForManufacturingOutcome" targetRef="Event_ManufacturingFailedOutcome" />
    <bpmn:sequenceFlow id="Flow_ManufacturingCompleted_To_SendPerformQc" sourceRef="Event_ManufacturingCompletedOutcome" targetRef="Activity_SendPerformQcCommand" />
    <bpmn:sequenceFlow id="Flow_ManufacturingFailed_To_End" sourceRef="Event_ManufacturingFailedOutcome" targetRef="Event_OrderFailed" />
    <bpmn:sequenceFlow id="Flow_SendPerformQc_To_WaitForQcOutcome" sourceRef="Activity_SendPerformQcCommand" targetRef="Gateway_WaitForQcOutcome" />
    <bpmn:sequenceFlow id="Flow_WaitForQcOutcome_To_Shipping" sourceRef="Gateway_WaitForQcOutcome" targetRef="Event_QcShippingOutcome" />
    <bpmn:sequenceFlow id="Flow_WaitForQcOutcome_To_Rejection" sourceRef="Gateway_WaitForQcOutcome" targetRef="Event_QcRejectionOutcome" />
    <bpmn:sequenceFlow id="Flow_QcShippingOutcome_To_End" sourceRef="Event_QcShippingOutcome" targetRef="Event_OrderCompleted" />
    <bpmn:sequenceFlow id="Flow_QcRejectionOutcome_To_End" sourceRef="Event_QcRejectionOutcome" targetRef="Event_OrderRejected" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_OrderOrchestration">
    <bpmndi:BPMNPlane id="BPMNPlane_OrderOrchestration" bpmnElement="OrderOrchestrationProcess">
      <bpmndi:BPMNShape id="Shape_StartEvent_OrderCreated" bpmnElement="StartEvent_OrderCreated">
        <dc:Bounds x="100" y="200" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Activity_SendRunIntakeCommand" bpmnElement="Activity_SendRunIntakeCommand">
        <dc:Bounds x="180" y="178" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Event_IntakeCompletedOutcome" bpmnElement="Event_IntakeCompletedOutcome">
        <dc:Bounds x="340" y="200" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Activity_SendRunProductionCommand" bpmnElement="Activity_SendRunProductionCommand">
        <dc:Bounds x="440" y="178" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_WaitForManufacturingOutcome" bpmnElement="Gateway_WaitForManufacturingOutcome" isMarkerVisible="true">
        <dc:Bounds x="605" y="193" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Event_ManufacturingCompletedOutcome" bpmnElement="Event_ManufacturingCompletedOutcome">
        <dc:Bounds x="720" y="140" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Event_ManufacturingFailedOutcome" bpmnElement="Event_ManufacturingFailedOutcome">
        <dc:Bounds x="720" y="260" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Activity_SendPerformQcCommand" bpmnElement="Activity_SendPerformQcCommand">
        <dc:Bounds x="820" y="118" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_WaitForQcOutcome" bpmnElement="Gateway_WaitForQcOutcome" isMarkerVisible="true">
        <dc:Bounds x="985" y="133" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Event_QcShippingOutcome" bpmnElement="Event_QcShippingOutcome">
        <dc:Bounds x="1100" y="90" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Event_QcRejectionOutcome" bpmnElement="Event_QcRejectionOutcome">
        <dc:Bounds x="1100" y="210" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Event_OrderCompleted" bpmnElement="Event_OrderCompleted">
        <dc:Bounds x="1260" y="90" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Event_OrderRejected" bpmnElement="Event_OrderRejected">
        <dc:Bounds x="1260" y="210" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Event_OrderFailed" bpmnElement="Event_OrderFailed">
        <dc:Bounds x="900" y="260" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_Flow_Start_To_SendRunIntake" bpmnElement="Flow_Start_To_SendRunIntake">
        <di:waypoint x="136" y="218" />
        <di:waypoint x="180" y="218" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_SendRunIntake_To_IntakeCompleted" bpmnElement="Flow_SendRunIntake_To_IntakeCompleted">
        <di:waypoint x="280" y="218" />
        <di:waypoint x="340" y="218" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_IntakeCompleted_To_SendRunProduction" bpmnElement="Flow_IntakeCompleted_To_SendRunProduction">
        <di:waypoint x="376" y="218" />
        <di:waypoint x="440" y="218" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_SendRunProduction_To_WaitForManufacturingOutcome" bpmnElement="Flow_SendRunProduction_To_WaitForManufacturingOutcome">
        <di:waypoint x="540" y="218" />
        <di:waypoint x="605" y="218" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_WaitForManufacturingOutcome_To_ManufacturingCompleted" bpmnElement="Flow_WaitForManufacturingOutcome_To_ManufacturingCompleted">
        <di:waypoint x="630" y="193" />
        <di:waypoint x="630" y="158" />
        <di:waypoint x="720" y="158" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_WaitForManufacturingOutcome_To_ManufacturingFailed" bpmnElement="Flow_WaitForManufacturingOutcome_To_ManufacturingFailed">
        <di:waypoint x="630" y="243" />
        <di:waypoint x="630" y="278" />
        <di:waypoint x="720" y="278" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_ManufacturingCompleted_To_SendPerformQc" bpmnElement="Flow_ManufacturingCompleted_To_SendPerformQc">
        <di:waypoint x="756" y="158" />
        <di:waypoint x="820" y="158" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_ManufacturingFailed_To_End" bpmnElement="Flow_ManufacturingFailed_To_End">
        <di:waypoint x="756" y="278" />
        <di:waypoint x="900" y="278" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_SendPerformQc_To_WaitForQcOutcome" bpmnElement="Flow_SendPerformQc_To_WaitForQcOutcome">
        <di:waypoint x="920" y="158" />
        <di:waypoint x="985" y="158" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_WaitForQcOutcome_To_Shipping" bpmnElement="Flow_WaitForQcOutcome_To_Shipping">
        <di:waypoint x="1010" y="133" />
        <di:waypoint x="1010" y="108" />
        <di:waypoint x="1100" y="108" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_WaitForQcOutcome_To_Rejection" bpmnElement="Flow_WaitForQcOutcome_To_Rejection">
        <di:waypoint x="1010" y="183" />
        <di:waypoint x="1010" y="228" />
        <di:waypoint x="1100" y="228" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_QcShippingOutcome_To_End" bpmnElement="Flow_QcShippingOutcome_To_End">
        <di:waypoint x="1136" y="108" />
        <di:waypoint x="1260" y="108" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_QcRejectionOutcome_To_End" bpmnElement="Flow_QcRejectionOutcome_To_End">
        <di:waypoint x="1136" y="228" />
        <di:waypoint x="1260" y="228" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
