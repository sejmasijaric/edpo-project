<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_OrderOrchestration"
                  targetNamespace="http://unisg.org/ftengrave/order-orchestrator">
  <bpmn:message id="Message_OrderCreated" name="OrderCreatedMessage" />

  <bpmn:process id="OrderOrchestrationProcess" name="Order Orchestration Process" isExecutable="true">
    <bpmn:startEvent id="StartEvent_OrderCreated" name="Order Created Event">
      <bpmn:outgoing>Flow_Start_To_SendPerformQc</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_OrderCreated"
                                   messageRef="Message_OrderCreated" />
    </bpmn:startEvent>
    <bpmn:sendTask id="Activity_SendPerformQcCommand"
                   name="Send Perform QC Command"
                   camunda:delegateExpression="${sendPerformQcCommandDelegate}">
      <bpmn:incoming>Flow_Start_To_SendPerformQc</bpmn:incoming>
      <bpmn:outgoing>Flow_SendPerformQc_To_End</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="Event_OrderOrchestrated" name="Order orchestrated">
      <bpmn:incoming>Flow_SendPerformQc_To_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start_To_SendPerformQc" sourceRef="StartEvent_OrderCreated" targetRef="Activity_SendPerformQcCommand" />
    <bpmn:sequenceFlow id="Flow_SendPerformQc_To_End" sourceRef="Activity_SendPerformQcCommand" targetRef="Event_OrderOrchestrated" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_OrderOrchestration">
    <bpmndi:BPMNPlane id="BPMNPlane_OrderOrchestration" bpmnElement="OrderOrchestrationProcess">
      <bpmndi:BPMNShape id="Shape_StartEvent_OrderCreated" bpmnElement="StartEvent_OrderCreated">
        <dc:Bounds x="160" y="100" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Activity_SendPerformQcCommand" bpmnElement="Activity_SendPerformQcCommand">
        <dc:Bounds x="260" y="78" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Event_OrderOrchestrated" bpmnElement="Event_OrderOrchestrated">
        <dc:Bounds x="520" y="100" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_Flow_Start_To_SendPerformQc" bpmnElement="Flow_Start_To_SendPerformQc">
        <di:waypoint x="196" y="118" />
        <di:waypoint x="260" y="118" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_SendPerformQc_To_End" bpmnElement="Flow_SendPerformQc_To_End">
        <di:waypoint x="360" y="118" />
        <di:waypoint x="520" y="118" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
