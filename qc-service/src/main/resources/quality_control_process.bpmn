    <bpmn:sequenceFlow id="Flow_1pcv6k5" name="Yes" sourceRef="Gateway_1ncsa2q" targetRef="Activity_0c13ean">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${qcPassed}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_0do0od1" sourceRef="Activity_1mrwlyg" targetRef="Gateway_1ncsa2q" />
    <bpmn:sequenceFlow id="Flow_0vgxl1h" name="No" sourceRef="Gateway_1ncsa2q" targetRef="Gateway_1knde2s">
