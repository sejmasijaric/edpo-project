  <bpmn:process id="qc_process" isExecutable="true">
    <bpmn:sequenceFlow id="Flow_1tuwaur" sourceRef="StartEvent_1" targetRef="Gateway_1i7gin2" />
    <bpmn:startEvent id="StartEvent_1" name="Item Arrived at QC">
      <bpmn:outgoing>Flow_1tuwaur</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_0czvh0v" messageRef="Message_1maa6ei" />
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="Gateway_0a372n8" name="Color Matches Order?">
      <bpmn:incoming>Flow_0hicsj9</bpmn:incoming>
      <bpmn:outgoing>Flow_11xvwaz</bpmn:outgoing>
      <bpmn:outgoing>Flow_10vm4zk</bpmn:outgoing>
