    <bpmn:sequenceFlow id="Flow_09xv5l2" name="No Color Detected" sourceRef="Event_17dlz0w" targetRef="Activity_031az9x" />
    <bpmn:sequenceFlow id="Flow_10vm4zk" name="Color Correct" sourceRef="Gateway_0a372n8" targetRef="Activity_1mrwlyg">
