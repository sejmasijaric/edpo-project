    <bpmn:userTask id="Activity_0s7hwfg" name="Resolve Issue and Restore Item Position">
      <bpmn:documentation>1. Disable conveyor belt by triggering i3 Light Barrier
2. Identify why the item did not arrive on time
3. Restore the position of the item to before the color sensor</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:formData />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0wwlqry</bpmn:incoming>
      <bpmn:outgoing>Flow_1pcwhbc</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_1pcwhbc" sourceRef="Activity_0s7hwfg" targetRef="Gateway_1i7gin2" />
