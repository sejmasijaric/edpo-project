    <bpmn:sequenceFlow id="Flow_0bfxafc" sourceRef="Activity_1wtp2k8" targetRef="Activity_1vhipym" />
    <bpmn:serviceTask id="Activity_0dwpaza" name="Sorting Machine Sort to Rejection Sink" camunda:delegateExpression="${SortToRejectionAdapter}">
      <bpmn:extensionElements />
      <bpmn:incoming>Flow_0q1zuzk</bpmn:incoming>
      <bpmn:outgoing>Flow_02ip3b5</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_11xvwaz" name="Color Incorrect" sourceRef="Gateway_0a372n8" targetRef="Gateway_1knde2s">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${!passedColorCheck}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:serviceTask id="Activity_031az9x" name="Sorting Machine Sort to Re-Try Sink" camunda:delegateExpression="${SortToRetryAdapter}">
      <bpmn:extensionElements />
      <bpmn:incoming>Flow_09xv5l2</bpmn:incoming>
      <bpmn:outgoing>Flow_0f506hl</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_0c13ean" name="Sorting Machine Sort to Shipping Sink" camunda:delegateExpression="${SortToShippingAdapter}">
